<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Theme.VoiceOS — Hybrid theme used across the whole app.

        • MainActivity (Compose)  → only uses this for window chrome
          (background, status-bar colour). Compose MaterialTheme handles
          everything else via VoiceOSTheme in MainScreen.kt.

        • MacrosActivity (XML/ViewBinding) → uses this fully for toolbar,
          cards, buttons, and all Material3 widget styling.

        We extend Theme.Material3.DayNight.NoActionBar so that both use-cases
        get proper Material3 defaults while still working with ActionBar
        via Toolbar in MacrosActivity.
    -->
    <style name="Theme.VoiceOS" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Accent / primary colours -->
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorPrimaryDark">#1557B0</item>
        <item name="colorAccent">#1A73E8</item>

        <!-- Window chrome — matches Compose dark background -->
        <item name="android:windowBackground">#0F1117</item>
        <item name="android:statusBarColor">#0F1117</item>
        <item name="android:navigationBarColor">#0F1117</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Disable the default window enter animation so Compose
             handles its own slide-up animation cleanly -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!--
        Theme.VoiceOS.Macros — slight variant for MacrosActivity.
        Adds the toolbar / CollapsingToolbar surface colour so the
        AppBarLayout background is consistent with the dark palette.
    -->
    <style name="Theme.VoiceOS.Macros" parent="Theme.VoiceOS">
        <item name="android:windowBackground">#0F1117</item>
        <item name="colorSurface">#13161F</item>
        <item name="colorOnSurface">#EAEDF3</item>
    </style>

</resources>
