<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility Service Configuration
    - Listens to ALL apps (no packageNames filter)
    - Captures window content changes so we can read UI element layout
    - Allows interaction (click/scroll)
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged|typeViewScrolled"
    android:accessibilityFeedbackType="feedbackAllMask"
    android:accessibilityFlags="flagDefault|flagRetrieveInteractiveWindows|flagRequestEnhancedWebAccessibility"
    android:canPerformGestures="true"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity="com.voiceos.ui.MainActivity" />
