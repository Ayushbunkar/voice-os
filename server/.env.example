# ============================================================
# VoiceOS Cloud — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voiceos_db
DB_USER=voiceos_user
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_SSL=false
DATABASE_URL=postgresql://voiceos_user:REPLACE_WITH_DB_PASSWORD@localhost:5432/voiceos_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.2

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_WITH_PRO_PRICE_ID
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_REPLACE_WITH_ENTERPRISE_PRICE_ID

# ── Razorpay (optional – Indian payments) ─────────────────────
RAZORPAY_KEY_ID=REPLACE_WITH_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_RAZORPAY_WEBHOOK_SECRET
RAZORPAY_PLAN_PRO_MONTHLY=plan_REPLACE_WITH_PRO_PLAN_ID
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=plan_REPLACE_WITH_ENTERPRISE_PLAN_ID

# ── Frontend URL (CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ANDROID_APP_DOWNLOAD_URL=https://voiceos.app/download/voiceos-latest.apk

# ── Email (optional – for notifications) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_EMAIL
SMTP_PASS=REPLACE_WITH_EMAIL_APP_PASSWORD
EMAIL_FROM=noreply@voiceos.app

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20

# ── Plan Limits ───────────────────────────────────────────────
FREE_COMMANDS_PER_DAY=50
PRO_COMMANDS_PER_DAY=1000
ENTERPRISE_COMMANDS_PER_DAY=999999

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log
